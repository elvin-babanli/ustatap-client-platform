# Production environment
# Copy to .env and fill in real values before deploy

# API (apps/api)
PORT=3001
NODE_ENV=production
DATABASE_URL=postgresql://user:password@host:5432/ustatap
JWT_ACCESS_SECRET=REQUIRED-min-32-characters-secure-random
JWT_REFRESH_SECRET=REQUIRED-min-32-characters-secure-random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
APP_DEFAULT_COMMISSION_RATE=0.05
PAYMENT_PROVIDER_LABEL=INTERNAL_PLACEHOLDER
CORS_ORIGINS=https://your-domain.com

# Web (apps/web)
NEXT_PUBLIC_API_URL=https://api.your-domain.com
