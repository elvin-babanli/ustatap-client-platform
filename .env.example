# ===========================================
# API (apps/api)
# ===========================================
PORT=3001
NODE_ENV=development
API_PREFIX=api/v1

# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/ustatap

# JWT (required; production: min 32 chars each)
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Payments (foundation - no gateway)
APP_DEFAULT_COMMISSION_RATE=0.05
PAYMENT_PROVIDER_LABEL=INTERNAL_PLACEHOLDER

# CORS (comma-separated; dev defaults to localhost:3000)
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Redis (future)
# REDIS_URL=redis://localhost:6379

# S3-compatible storage (future)
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=

# ===========================================
# Web (apps/web) - NEXT_PUBLIC_* exposed to client
# ===========================================
# NEXT_PUBLIC_API_URL=http://localhost:3001
