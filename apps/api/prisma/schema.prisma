// Ustatap Client Platform - Database Schema
// PostgreSQL + Prisma ORM
// Naming: PascalCase models, camelCase fields, snake_case tables via @@map

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  CUSTOMER
  MASTER
  ADMIN

  @@map("user_role")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION

  @@map("user_status")
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("verification_status")
}

enum DocumentType {
  ID_CARD
  PASSPORT
  BUSINESS_LICENSE
  OTHER

  @@map("document_type")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED

  @@map("booking_status")
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN

  @@map("review_status")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED

  @@map("payment_status")
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  CASH
  WALLET
  OTHER

  @@map("payment_method")
}

enum CommissionStatus {
  PENDING
  COLLECTED
  WAIVED

  @@map("commission_status")
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED

  @@map("payout_status")
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  REVIEW_RECEIVED
  SYSTEM
  OTHER

  @@map("notification_type")
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED

  @@map("dispute_status")
}

enum DisputeIssueType {
  OVERCHARGE
  BAD_QUALITY
  NO_SHOW
  SAFETY_ISSUE
  PAYMENT_ISSUE
  OTHER

  @@map("dispute_issue_type")
}

enum SupportedLanguage {
  AZ
  EN
  RU

  @@map("supported_language")
}

enum Currency {
  AZN
  USD
  EUR
  RUB

  @@map("currency")
}

// =============================================================================
// MODELS
// =============================================================================

model User {
  id            String       @id @default(uuid()) @db.Uuid
  email         String?      @unique @db.VarChar(255)
  phone         String       @unique @db.VarChar(50)
  passwordHash  String       @map("password_hash") @db.VarChar(255)
  role          UserRole
  status        UserStatus   @default(PENDING_VERIFICATION)
  isPhoneVerified Boolean    @default(false) @map("is_phone_verified") @db.Boolean
  isEmailVerified Boolean    @default(false) @map("is_email_verified") @db.Boolean
  lastLoginAt   DateTime?    @map("last_login_at") @db.Timestamptz
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  customerProfile           CustomerProfile?
  masterProfile             MasterProfile?
  addresses                 Address[]
  bookingsAsCustomer        Booking[]              @relation("BookingCustomer")
  reviewReplies             ReviewReply[]            @relation("ReviewReplyAuthor")
  notifications             Notification[]
  auditLogs                 AuditLog[]              @relation("AuditLogActor")
  disputesOpened            Dispute[]               @relation("DisputeOpenedBy")
  disputesAssigned          Dispute[]               @relation("DisputeAssignedTo")
  paymentsAsPayer           Payment[]               @relation("PaymentPayer")
  paymentsAsPayee           Payment[]               @relation("PaymentPayee")
  bookingStatusChanges      BookingStatusHistory[]  @relation("StatusChangedBy")
  documentsReviewed        MasterVerificationDocument[] @relation("DocumentReviewedBy")
  masterProfilesReviewed   MasterProfile[]              @relation("MasterProfileReviewedBy")
  sessions                 Session[]
  passwordResetTokens      PasswordResetToken[]
  messagesSent             Message[]

  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model CustomerProfile {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @unique @map("user_id") @db.Uuid
  firstName         String    @map("first_name") @db.VarChar(100)
  lastName          String    @map("last_name") @db.VarChar(100)
  avatarUrl         String?   @map("avatar_url") @db.VarChar(500)
  preferredLanguage SupportedLanguage @default(EN) @map("preferred_language")
  dateOfBirth       DateTime? @map("date_of_birth") @db.Date
  notes             String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews  Review[]

  @@map("customer_profiles")
}

model MasterProfile {
  id                  String             @id @default(uuid()) @db.Uuid
  userId              String             @unique @map("user_id") @db.Uuid
  displayName         String             @map("display_name") @db.VarChar(150)
  bio                 String?            @db.Text
  experienceYears     Int?               @map("experience_years") @db.Integer
  avatarUrl           String?            @map("avatar_url") @db.VarChar(500)
  verificationStatus  VerificationStatus @default(PENDING) @map("verification_status")
  rejectionReason     String?            @map("rejection_reason") @db.Text
  reviewedByUserId    String?            @map("reviewed_by_user_id") @db.Uuid
  reviewedAt          DateTime?          @map("reviewed_at") @db.Timestamptz
  averageRating       Decimal            @default(0) @map("average_rating") @db.Decimal(3, 2)
  totalReviews        Int                @default(0) @map("total_reviews") @db.Integer
  isAvailable         Boolean            @default(true) @map("is_available") @db.Boolean
  completedJobsCount  Int                @default(0) @map("completed_jobs_count") @db.Integer
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  user                  User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy            User?                      @relation("MasterProfileReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  verificationDocuments MasterVerificationDocument[]
  masterServices        MasterService[]
  serviceAreas          ServiceArea[]
  bookings              Booking[]
  reviews               Review[]
  payouts               Payout[]

  @@index([verificationStatus])
  @@index([isAvailable])
  @@index([averageRating])
  @@map("master_profiles")
}

model MasterVerificationDocument {
  id               String             @id @default(uuid()) @db.Uuid
  masterProfileId  String             @map("master_profile_id") @db.Uuid
  documentType     DocumentType       @map("document_type")
  fileUrl          String             @map("file_url") @db.VarChar(500)
  originalFileName String?            @map("original_file_name") @db.VarChar(255)
  status           VerificationStatus @default(PENDING)
  reviewedByUserId String?            @map("reviewed_by_user_id") @db.Uuid
  reviewedAt       DateTime?          @map("reviewed_at") @db.Timestamptz
  rejectionReason  String?            @map("rejection_reason") @db.Text
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  masterProfile MasterProfile @relation(fields: [masterProfileId], references: [id], onDelete: Cascade)
  reviewedBy    User?         @relation("DocumentReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([masterProfileId])
  @@index([status])
  @@map("master_verification_documents")
}

model ServiceCategory {
  id            String   @id @default(uuid()) @db.Uuid
  nameAz        String   @map("name_az") @db.VarChar(150)
  nameEn        String   @map("name_en") @db.VarChar(150)
  nameRu        String   @map("name_ru") @db.VarChar(150)
  slug          String   @unique @db.VarChar(150)
  descriptionAz String?  @map("description_az") @db.Text
  descriptionEn String?  @map("description_en") @db.Text
  descriptionRu String?  @map("description_ru") @db.Text
  isActive      Boolean  @default(true) @map("is_active") @db.Boolean
  sortOrder     Int      @default(0) @map("sort_order") @db.Integer
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  services Service[]

  @@index([slug])
  @@index([isActive, sortOrder])
  @@map("service_categories")
}

model Service {
  id            String   @id @default(uuid()) @db.Uuid
  categoryId    String   @map("category_id") @db.Uuid
  nameAz        String   @map("name_az") @db.VarChar(150)
  nameEn        String   @map("name_en") @db.VarChar(150)
  nameRu        String   @map("name_ru") @db.VarChar(150)
  slug          String   @db.VarChar(150)
  descriptionAz String?  @map("description_az") @db.Text
  descriptionEn String?  @map("description_en") @db.Text
  descriptionRu String?  @map("description_ru") @db.Text
  isActive      Boolean  @default(true) @map("is_active") @db.Boolean
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  category       ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  masterServices MasterService[]
  bookings       Booking[]

  @@unique([categoryId, slug])
  @@index([categoryId])
  @@index([slug])
  @@map("services")
}

model MasterService {
  id              String   @id @default(uuid()) @db.Uuid
  masterProfileId String   @map("master_profile_id") @db.Uuid
  serviceId       String   @map("service_id") @db.Uuid
  basePrice       Decimal  @map("base_price") @db.Decimal(12, 2)
  currency        Currency
  isActive        Boolean  @default(true) @map("is_active") @db.Boolean
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  masterProfile MasterProfile @relation(fields: [masterProfileId], references: [id], onDelete: Cascade)
  service      Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  bookings    Booking[]

  @@unique([masterProfileId, serviceId])
  @@index([masterProfileId])
  @@index([serviceId])
  @@map("master_services")
}

model Address {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  label     String?  @db.VarChar(100)
  country   String   @db.VarChar(100)
  city      String   @db.VarChar(100)
  district  String?  @db.VarChar(100)
  street    String?  @db.VarChar(200)
  building  String?  @db.VarChar(50)
  apartment String?  @db.VarChar(50)
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  postalCode String? @map("postal_code") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  bookings Booking[]

  @@index([userId])
  @@map("addresses")
}

model ServiceArea {
  id              String   @id @default(uuid()) @db.Uuid
  masterProfileId String   @map("master_profile_id") @db.Uuid
  city            String   @db.VarChar(100)
  district        String?  @db.VarChar(100)
  latitude        Decimal? @db.Decimal(10, 8)
  longitude       Decimal? @db.Decimal(11, 8)
  radiusKm        Decimal? @map("radius_km") @db.Decimal(6, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  masterProfile MasterProfile @relation(fields: [masterProfileId], references: [id], onDelete: Cascade)

  @@index([masterProfileId])
  @@index([city])
  @@map("service_areas")
}

model Booking {
  id                  String        @id @default(uuid()) @db.Uuid
  customerUserId      String        @map("customer_user_id") @db.Uuid
  masterProfileId     String        @map("master_profile_id") @db.Uuid
  masterServiceId     String        @map("master_service_id") @db.Uuid
  serviceId           String        @map("service_id") @db.Uuid
  addressId           String        @map("address_id") @db.Uuid
  status              BookingStatus @default(PENDING)
  scheduledDate       DateTime      @map("scheduled_date") @db.Date
  scheduledTimeStart  DateTime      @map("scheduled_time_start") @db.Time
  scheduledTimeEnd    DateTime      @map("scheduled_time_end") @db.Time
  problemDescription  String?       @map("problem_description") @db.Text
  estimatedPrice      Decimal       @map("estimated_price") @db.Decimal(12, 2)
  finalPrice          Decimal?      @map("final_price") @db.Decimal(12, 2)
  currency            Currency
  internalNotes       String?       @map("internal_notes") @db.Text
  canceledAt          DateTime?     @map("canceled_at") @db.Timestamptz
  completedAt         DateTime?     @map("completed_at") @db.Timestamptz
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  customer      User                  @relation("BookingCustomer", fields: [customerUserId], references: [id], onDelete: Restrict)
  masterProfile MasterProfile         @relation(fields: [masterProfileId], references: [id], onDelete: Restrict)
  masterService MasterService         @relation(fields: [masterServiceId], references: [id], onDelete: Restrict)
  service       Service               @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  address       Address               @relation(fields: [addressId], references: [id], onDelete: Restrict)
  statusHistory BookingStatusHistory[]
  attachments   BookingAttachment[]
  review        Review?
  payments      Payment[]
  dispute       Dispute?
  messageThread MessageThread?

  @@index([customerUserId])
  @@index([masterProfileId])
  @@index([status])
  @@index([scheduledDate])
  @@index([createdAt])
  @@map("bookings")
}

model BookingStatusHistory {
  id             String        @id @default(uuid()) @db.Uuid
  bookingId      String        @map("booking_id") @db.Uuid
  fromStatus     BookingStatus @map("from_status")
  toStatus       BookingStatus @map("to_status")
  changedByUserId String       @map("changed_by_user_id") @db.Uuid
  note           String?       @db.Text
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz

  booking     Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  changedBy   User    @relation("StatusChangedBy", fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@index([createdAt])
  @@map("booking_status_history")
}

model BookingAttachment {
  id        String   @id @default(uuid()) @db.Uuid
  bookingId String   @map("booking_id") @db.Uuid
  fileUrl   String   @map("file_url") @db.VarChar(500)
  fileType  String?  @map("file_type") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_attachments")
}

model Review {
  id              String       @id @default(uuid()) @db.Uuid
  bookingId       String       @unique @map("booking_id") @db.Uuid
  customerId      String       @map("customer_id") @db.Uuid
  masterProfileId String       @map("master_profile_id") @db.Uuid
  rating          Int          @db.SmallInt
  comment         String?      @db.Text
  status          ReviewStatus @default(PENDING)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  booking    Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer   CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Restrict)
  masterProfile MasterProfile @relation(fields: [masterProfileId], references: [id], onDelete: Restrict)
  replies    ReviewReply[]

  @@index([masterProfileId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("reviews")
}

model ReviewReply {
  id        String   @id @default(uuid()) @db.Uuid
  reviewId  String   @map("review_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  comment   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation("ReviewReplyAuthor", fields: [userId], references: [id], onDelete: Restrict)

  @@index([reviewId])
  @@map("review_replies")
}

model Payment {
  id                 String        @id @default(uuid()) @db.Uuid
  bookingId          String        @map("booking_id") @db.Uuid
  payerUserId        String        @map("payer_user_id") @db.Uuid
  payeeUserId        String?       @map("payee_user_id") @db.Uuid
  amount             Decimal       @db.Decimal(12, 2)
  currency           Currency
  status             PaymentStatus @default(PENDING)
  method             PaymentMethod
  provider           String?       @db.VarChar(100)
  providerReference  String?       @map("provider_reference") @db.VarChar(255)
  idempotencyKey     String?       @unique @map("idempotency_key") @db.VarChar(255)
  failureReason      String?       @map("failure_reason") @db.Text
  paidAt             DateTime?     @map("paid_at") @db.Timestamptz
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  booking    Booking     @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  payer      User        @relation("PaymentPayer", fields: [payerUserId], references: [id], onDelete: Restrict)
  payee      User?       @relation("PaymentPayee", fields: [payeeUserId], references: [id], onDelete: SetNull)
  commission Commission?

  @@index([bookingId])
  @@index([payerUserId])
  @@index([status])
  @@index([createdAt])
  @@index([idempotencyKey])
  @@map("payments")
}

model Commission {
  id        String          @id @default(uuid()) @db.Uuid
  paymentId String          @unique @map("payment_id") @db.Uuid
  rate      Decimal         @db.Decimal(5, 4)
  amount    Decimal         @db.Decimal(12, 2)
  currency  Currency
  status    CommissionStatus @default(PENDING)
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@index([status])
  @@map("commissions")
}

model Payout {
  id              String       @id @default(uuid()) @db.Uuid
  masterProfileId String       @map("master_profile_id") @db.Uuid
  amount          Decimal      @db.Decimal(12, 2)
  currency        Currency
  status          PayoutStatus @default(PENDING)
  processedAt     DateTime?    @map("processed_at") @db.Timestamptz
  reference       String?      @db.VarChar(255)
  notes           String?      @db.Text
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  masterProfile MasterProfile @relation(fields: [masterProfileId], references: [id], onDelete: Restrict)

  @@index([masterProfileId])
  @@index([status])
  @@index([createdAt])
  @@map("payouts")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(255)
  message   String?          @db.Text
  isRead    Boolean          @default(false) @map("is_read") @db.Boolean
  readAt    DateTime?        @map("read_at") @db.Timestamptz
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Dispute {
  id                   String           @id @default(uuid()) @db.Uuid
  bookingId            String           @unique @map("booking_id") @db.Uuid
  openedByUserId       String           @map("opened_by_user_id") @db.Uuid
  assignedAdminUserId  String?          @map("assigned_admin_user_id") @db.Uuid
  status               DisputeStatus    @default(OPEN)
  issueType            DisputeIssueType @default(OTHER) @map("issue_type")
  reason               String           @db.Text
  attachmentUrls       Json             @default("[]") @map("attachment_urls") @db.JsonB
  resolutionNote       String?          @map("resolution_note") @db.Text
  resolvedAt           DateTime?        @map("resolved_at") @db.Timestamptz
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  booking           Booking @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  openedBy          User    @relation("DisputeOpenedBy", fields: [openedByUserId], references: [id], onDelete: Restrict)
  assignedAdmin     User?   @relation("DisputeAssignedTo", fields: [assignedAdminUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([openedByUserId])
  @@map("disputes")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  entityType   String   @map("entity_type") @db.VarChar(100)
  entityId     String   @map("entity_id") @db.Uuid
  action       String   @db.VarChar(50)
  metadata     Json?    @db.JsonB
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  actor User? @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(64)
  deviceInfo       String?   @map("device_info") @db.VarChar(255)
  ipAddress        String?   @map("ip_address") @db.VarChar(45)
  userAgent        String?   @map("user_agent") @db.Text
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("sessions")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  codeHash  String   @map("code_hash") @db.VarChar(64)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model MessageThread {
  id        String   @id @default(uuid()) @db.Uuid
  bookingId String   @unique @map("booking_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("message_threads")
}

model Message {
  id          String   @id @default(uuid()) @db.Uuid
  threadId    String   @map("thread_id") @db.Uuid
  senderId    String   @map("sender_id") @db.Uuid
  content     String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([threadId])
  @@index([createdAt])
  @@map("messages")
}
