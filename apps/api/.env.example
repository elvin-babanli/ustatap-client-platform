# NestJS API environment variables
# Copy to .env for local development
# Config validation runs at startup - invalid/missing required vars will fail fast

PORT=3001
NODE_ENV=development
API_PREFIX=api/v1

# Database (required)
# Local Docker (docker-compose): Postgres is published on host port 5433
DATABASE_URL=postgresql://ustatap:ustatap_secret@localhost:5433/ustatap

# JWT (required; production: min 32 chars each)
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Password hashing (10-14 rounds)
BCRYPT_SALT_ROUNDS=12

# Payments (foundation)
APP_DEFAULT_COMMISSION_RATE=0.05
PAYMENT_PROVIDER_LABEL=INTERNAL_PLACEHOLDER

# CORS (comma-separated origins; dev defaults to localhost:3000)
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Redis (future)
# REDIS_URL=redis://localhost:6379
